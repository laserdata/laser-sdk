{
  "name": "@laserdata/laser-sdk",
  "version": "0.0.1-rc.1",
  "description": "LaserData SDK for TypeScript: an open data-platform SDK over Apache Iggy (typed streaming, declared projections and a query DSL, a key-value store, copy-on-write forks, and an optional agent runtime with AGDX)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./full": {
      "types": "./dist/full.d.ts",
      "import": "./dist/full.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    },
    "./opentelemetry": {
      "types": "./dist/opentelemetry.d.ts",
      "import": "./dist/opentelemetry.js"
    }
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laserdata/laser-sdk.git",
    "directory": "foreign/typescript"
  },
  "homepage": "https://laserdata.com",
  "bugs": {
    "url": "https://github.com/laserdata/laser-sdk/issues"
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "clean": "node ./scripts/clean.mjs",
    "style:check": "node ./scripts/style-check.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "boundaries:check": "node ./scripts/boundary-check.mjs",
    "typecheck": "node ./node_modules/@typescript/native/bin/tsc -p tsconfig.json --noEmit",
    "build": "node ./node_modules/@typescript/native/bin/tsc -p tsconfig.build.json",
    "build:test": "node ./node_modules/@typescript/native/bin/tsc -p tsconfig.test.json",
    "api:report": "node ./scripts/api-report.mjs",
    "api:check": "node ./scripts/api-check.mjs",
    "test:unit": "node ./scripts/run-tests.mjs unit",
    "test:wire": "node ./scripts/run-tests.mjs wire",
    "test:robustness": "node ./scripts/run-tests.mjs robustness",
    "test:integration": "node ./scripts/run-tests.mjs integration",
    "test": "npm run test:unit && npm run test:wire && npm run test:robustness",
    "coverage": "c8 --all --src src --check-coverage --lines 70 --functions 70 --branches 60 --statements 70 node ./scripts/run-tests.mjs unit wire robustness",
    "pack:check": "node ./scripts/pack-check.mjs",
    "pack:consumer": "node ./scripts/pack-consumer-check.mjs",
    "license:check": "node ./scripts/license-check.mjs",
    "sbom": "node ./scripts/sbom.mjs",
    "release:validate": "node ./scripts/validate-release.mjs",
    "release:publish": "node ./scripts/publish-release.mjs",
    "verify": "npm run style:check && npm run format:check && npm run lint && npm run typecheck && npm run build && npm run boundaries:check && npm run build:test && npm run api:check && npm run test && npm run coverage && npm run license:check && npm run pack:check && npm run pack:consumer"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@noble/ed25519": "3.1.0",
    "@noble/hashes": "2.2.0",
    "@types/node": "22.20.1",
    "ajv": "8.20.0",
    "apache-iggy": "0.8.1-edge.2",
    "avsc": "5.7.9",
    "cborg": "^5.1.8",
    "protobufjs": "8.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@microsoft/api-extractor": "^7.58.12",
    "@typescript/native": "npm:typescript@7.0.2",
    "c8": "^12.0.0",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "prettier": "3.9.6",
    "typescript": "npm:@typescript/typescript6@6.0.3",
    "typescript-eslint": "8.65.0"
  }
}
